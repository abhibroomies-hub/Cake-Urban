rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == "abhibroomies@gmail.com"
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validations ---
    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.price is number && data.price >= 0 &&
             data.categories is list && data.categories.size() > 0;
    }

    function isValidOrder(data) {
      return data.total is number && data.total >= 0 &&
             data.status is string && data.status in ['new', 'baking', 'out-for-delivery', 'delivered', 'cancelled'] &&
             data.items is list && data.items.size() > 0 &&
             data.createdAt == request.time;
    }

    function isValidUser(data) {
      return data.email is string && data.email == request.auth.token.email &&
             (data.role == 'customer' || isAdmin()); // Protect role modification
    }

    function isValidReview(data) {
      return data.productId is string && data.userId == request.auth.uid &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() > 0 &&
             data.createdAt == request.time;
    }

    // --- Collections ---

    // Connection Test
    match /test/connection {
      allow read: if true;
    }

    // Admins Collection
    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via console
    }

    // Products
    match /products/{productId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidProduct(incoming());
      allow delete: if isAdmin();
    }

    // Categories
    match /categories/{categoryId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Reviews
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidReview(incoming());
      allow update, delete: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
    }

    // Orders
    match /orders/{orderId} {
      allow get: if (isSignedIn() && (isOwner(existing().userId) || existing().guestEmail == request.auth.token.email || isAdmin())) || (existing().userId != null && existing().userId.startsWith('local_user_'));
      allow list: if (isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin())) || (resource.data.userId != null && resource.data.userId.startsWith('local_user_'));
      allow create: if isValidOrder(incoming());
      allow update: if isAdmin() || (
        existing().userId != null && existing().userId.startsWith('local_user_') &&
        incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
        incoming().status == 'cancelled' &&
        existing().status == 'new'
      ) || (
        isOwner(existing().userId) && 
        incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
        incoming().status == 'cancelled' &&
        existing().status == 'new'
      );
    }

    function isValidCustomOrder(data) {
      return data.contactName is string && data.contactName.size() > 0 && data.contactName.size() < 200 &&
             data.contactEmail is string && data.contactEmail.size() > 0 && data.contactEmail.size() < 200 &&
             data.status is string;
    }

    // Users
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin() || (resource != null && resource.data.isLocalAccount == true);
      allow list: if isAdmin() || (request.query.limit <= 2);
      allow create: if (isOwner(userId) && isValidUser(incoming())) || (incoming().isLocalAccount == true);
      allow update: if (isOwner(userId) && isValidUser(incoming()) && 
                            (!existing().keys().has('role') || incoming().role == existing().role)) || 
                             (existing().isLocalAccount == true && incoming().isLocalAccount == true && incoming().role == 'customer');
    }

    // Custom Orders (Bespoke Inquiries)
    match /custom_orders/{orderId} {
      allow list, get: if isAdmin();
      allow create: if isValidCustomOrder(incoming());
      allow update, delete: if isAdmin();
    }

    // Global App Settings (including active default theme)
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
