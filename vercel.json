{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/:match*",
      "destination": "/api"
    },
    {
      "source": "/((?!api|assets|favicon\\.ico|favicon\\.png|robots\\.txt|llms\\.txt|sitemap\\.xml|sitemap_core\\.xml|sitemap_sectors\\.xml|sitemap_specialties\\.xml|sitemap_combinations\\.xml).*)$",
      "destination": "/index.html"
    }
  ]
}
