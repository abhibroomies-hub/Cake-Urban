{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/:match*",
      "destination": "/api"
    },
    {
      "source": "/((?!api|assets|favicon.ico|sitemap\\.xml|robots\\.txt).*|.*\\.(?:html|js|css|png|jpg|jpeg|gif|svg|webp|ico|woff2?|ttf|eot|xml|txt)$)",
      "destination": "/index.html"
    }
  ]
}
