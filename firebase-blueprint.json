{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A cake or bakery item available for purchase",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "categories": { "type": "array", "items": { "type": "string" } },
        "occasions": { "type": "array", "items": { "type": "string" } },
        "flavors": { "type": "array", "items": { "type": "string" } },
        "images": { "type": "array", "items": { "type": "string" } },
        "stockStatus": { "type": "string", "enum": ["in-stock", "out-of-stock"] },
        "isCustomizable": { "type": "boolean" },
        "weights": { "type": "array", "items": { "type": "number" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "categories"]
    },
    "Category": {
      "title": "Category",
      "description": "Product category (e.g., Chocolate, Fruit Cakes)",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "image": { "type": "string" }
      },
      "required": ["name"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "guestEmail": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["new", "baking", "out-for-delivery", "delivered", "cancelled"] },
        "paymentStatus": { "type": "string" },
        "shippingAddress": { "type": "object" },
        "deliveryDate": { "type": "string" },
        "deliverySlot": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["total", "status", "createdAt"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Customer information",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "addresses": { "type": "array" },
        "role": { "type": "string", "enum": ["customer", "admin"] }
      }
    },
    "Review": {
      "title": "Review",
      "description": "A customer review for a product",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "userId", "rating", "comment", "createdAt"]
    },
    "CustomOrder": {
      "title": "Custom Order Inquiry",
      "description": "A customized cake design inquiry requested by a customer",
      "type": "object",
      "properties": {
        "flavor": { "type": "string" },
        "shape": { "type": "string" },
        "tiers": { "type": "string" },
        "icingColor": { "type": "string" },
        "cakeMessage": { "type": "string" },
        "referenceImages": { "type": "array", "items": { "type": "string" } },
        "contactName": { "type": "string" },
        "contactEmail": { "type": "string" },
        "eventDate": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["contactName", "contactEmail", "status", "createdAt"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Store for all cakes and products"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Product categories"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles and data"
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Product reviews"
    },
    "/custom_orders/{orderId}": {
      "schema": "CustomOrder",
      "description": "Store for bespoke user interactive inquiries"
    }
  }
}
